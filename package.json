{
  "scripts": {
    "dev": "npm-run-all --parallel rspack eleventy",
    "rspack": "rspack build --watch --config rspack.config.js",
    "eleventy": "eleventy --watch --serve",
    "debug": "set DEBUG=* & eleventy",
    "build": "cross-env NODE_ENV=production eleventy && cross-env NODE_ENV=production rspack build --config rspack.config.js",
    "browsersync": "browser-sync start --server _site --files _site --port 8080 --no-notify --no-open"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@splidejs/splide": "^4.1.4",
    "babel-loader": "^10.1.1",
    "browser-sync": "^3.0.4",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "npm-run-all": "^4.1.5",
    "postcss-advanced-variables": "^5.0.0",
    "postcss-atroot": "^0.2.4",
    "postcss-cli": "^11.0.1",
    "postcss-custom-media": "^12.0.1",
    "postcss-easy-import": "^4.0.0",
    "postcss-extend-rule": "^4.0.0",
    "postcss-loader": "^8.2.1",
    "postcss-property-lookup": "^3.0.0",
    "postcss-rem": "^3.1.0",
    "postcss-scss": "^4.0.9"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@glidejs/glide": "^3.7.1",
    "autoprefixer": "^10.5.0",
    "decap-cms-app": "^3.12.2",
    "eleventy-plugin-page-assets": "github:maxboeck/eleventy-plugin-page-assets",
    "html-minifier-terser": "^7.2.0",
    "lodash": "^4.18.1",
    "macy": "^2.5.1",
    "slugify": "^1.6.9"
  }
}
